# =========================
# SERVER CONFIG
# =========================
PORT=5000
NODE_ENV=development

# =========================
# DATABASE (MongoDB)
# =========================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/superwin-casino?retryWrites=true&w=majority

# =========================
# AUTH
# =========================
JWT_SECRET=superwin_casino_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# =========================
# SOCKET CONFIG
# =========================
SOCKET_CORS_ORIGIN=*

# =========================
# WALLET SYSTEM
# =========================
INITIAL_WALLET_BALANCE=1000

# =========================
# CRASH GAME ENGINE
# =========================
CRASH_INTERVAL_MS=100
CRASH_MAX_MULTIPLIER=1000
CRASH_PROBABILITY=0.97

# =========================
# SECURITY
# =========================
BCRYPT_SALT_ROUNDS=10

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug
